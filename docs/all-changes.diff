-    try{
-      const ev=JSON.parse(e.data)
-      if(ev.type==="state"){
-        const prev=S.busy
-        const prevModel=S.modelOverride
-        const serverChatLog=ev.data.chatLog
-        const {chatLog:_cl,...rest}=ev.data
-        Object.assign(S,rest)
