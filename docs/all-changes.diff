-      const slice = content.slice(sym.start, endOffset);
-      symbols.push({
-        name: sym.name,
-        kind: sym.kind,
-        startLine: sym.lineNo,
-        endLine: endLineNo,
-        signature: slice.split("\n")[0].trim().slice(0, 200),
-        hash: hashSlice(slice)
