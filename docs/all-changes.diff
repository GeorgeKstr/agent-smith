-  }
-
-  // Methods inside class/struct bodies
-  const methodRe = /(?:^|\n)[ \t]+(?:virtual\s+|static\s+|inline\s+)?(?:[\w:*&<>,\s]+[\s*&])?\s*(\w+)\s*\(([^)]*)\)\s*(?:const|override|final|noexcept)?\s*\{/g;
