-      const af=an.__file,bf=bn.__file
-      if(af!==bf)return af?1:-1
-      return a.localeCompare(b)
-    })
-    el.innerHTML=sorted.map(([n,nd])=>renderTreeNode(n,nd,0)).join('')
-  }catch{}
-}
