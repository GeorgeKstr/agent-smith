-    const response = await fetchWithTimeout(
-      `${apiBase(args.baseUrl)}/api/generate`,
-      {
-        method: "POST",
-        headers: { "Content-Type": "application/json" },
-        body: JSON.stringify({
-          model: args.model,
-          prompt: args.prompt,
-          system: args.system,
